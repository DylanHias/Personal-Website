---
interface Props {
  /** Optional coord label, e.g. "§04". Rendered in accent when present. */
  index?: string;
  /** Small label above the title, e.g. "Certifications". */
  kicker: string;
  /** Large display title. */
  title: string;
  /** Optional right-rail annotation (e.g. "PROGRESS · 2/12"). */
  meta?: string;
}

const { index, kicker, title, meta } = Astro.props;
const hasBar = !!(index || meta);
---

<header data-reveal>
  {
    hasBar && (
      <div class="flex items-center justify-between gap-6 border-b border-line pb-3 mono text-[0.75rem] uppercase tracking-[0.22em] text-muted">
        <div class="flex items-center gap-3">
          {index && <span class="text-accent">{index}</span>}
          {index && <span class="text-subtle">/</span>}
          <span>{kicker}</span>
        </div>
        {meta && <span class="text-subtle">{meta}</span>}
      </div>
    )
  }
  {!hasBar && <p class="eyebrow">{kicker}</p>}
  <h2 class="section-title mt-6 text-fg">{title}</h2>
</header>
