---
const items = [
  {
    href: "https://www.linkedin.com/in/dylan-hias/",
    label: "LinkedIn",
    external: true,
    icon: "linkedin",
  },
  {
    href: "mailto:dylanhias21@gmail.com",
    label: "Email Dylan",
    external: false,
    icon: "mail",
  },
  {
    href: "/cv.pdf",
    label: "Download CV",
    external: false,
    icon: "file",
  },
];
---

<ul
  class="flex sm:flex-col items-center gap-3"
  aria-label="Profile links"
>
  {
    items.map((item) => (
      <li>
        <a
          href={item.href}
          aria-label={item.label}
          rel={item.external ? "me noopener" : undefined}
          target={item.external ? "_blank" : undefined}
          class="inline-flex h-10 w-10 items-center justify-center border border-line text-muted hover:border-accent hover:text-accent transition-colors"
        >
          {item.icon === "linkedin" && (
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M4.98 3.5A2.5 2.5 0 1 1 5 8.5a2.5 2.5 0 0 1 0-5zM3 9h4v12H3V9zm7 0h3.8v1.7h.05c.53-1 1.83-2.06 3.77-2.06 4.03 0 4.78 2.65 4.78 6.1V21h-4v-5.3c0-1.27-.02-2.9-1.77-2.9-1.77 0-2.04 1.38-2.04 2.8V21h-4V9z" />
            </svg>
          )}
          {item.icon === "mail" && (
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="5" width="18" height="14" rx="0" />
              <path d="m4 7 8 6 8-6" />
            </svg>
          )}
          {item.icon === "file" && (
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z" />
              <path d="M14 3v5h5" />
              <path d="M9 13h6M9 17h4" />
            </svg>
          )}
        </a>
      </li>
    ))
  }
</ul>
