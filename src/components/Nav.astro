---
const pathname = Astro.url.pathname;
const isHome = pathname === "/";

const links = [
  { href: isHome ? "#work" : "/#work", label: "Work" },
  { href: isHome ? "#experience" : "/#experience", label: "Experience" },
  { href: isHome ? "#contact" : "/#contact", label: "Contact" },
];
---

<nav
  class="absolute top-10 sm:top-12 left-0 right-0 z-30 flex items-center justify-between px-6 sm:px-10 py-4"
  aria-label="Primary"
>
  <a
    href="/"
    class="flex items-center gap-2 font-display text-fg tracking-wider"
    aria-label="Dylan Hias — home"
  >
    <span
      aria-hidden="true"
      class="text-muted text-sm leading-none"
      >{"{...}"}</span
    >
    <span class="text-xl leading-none"
      >DH<span class="text-subtle">/</span>SYSTEM<span class="text-accent"
        >.</span
      ></span
    >
  </a>

  <ul class="hidden sm:flex items-center gap-8 text-sm text-muted">
    {
      links.map((link) => (
        <li>
          <a
            href={link.href}
            class="hover:text-fg transition-colors"
          >
            {link.label}
          </a>
        </li>
      ))
    }
  </ul>

  <a
    href="mailto:dylanhias21@gmail.com"
    class="group inline-flex items-center gap-3 rounded-full bg-fg text-bg pl-5 pr-1 py-1 text-sm font-medium tracking-tight hover:bg-accent transition-colors"
  >
    <span>Get in touch</span>
    <span
      class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-accent text-bg transition-transform group-hover:translate-x-0.5 group-hover:bg-bg group-hover:text-accent"
      aria-hidden="true"
    >
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M5 12h14" />
        <path d="m13 5 7 7-7 7" />
      </svg>
    </span>
  </a>
</nav>
